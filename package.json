{
  "name": "notewell",
  "version": "1.0.5",
  "description": "A lightweight Markdown-first personal LLM wiki CLI",
  "type": "module",
  "bin": {
    "notewell": "dist/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "build": "tsc",
    "dev": "tsx src/cli.ts"
  },
  "files": [
    "dist",
    "src/templates",
    "docs/agent-workflows.md",
    "docs/commands.md",
    "docs/mcp.md",
    "docs/obsidian.md",
    "docs/quickstart.md",
    "docs/search-backends.md",
    "docs/version-roadmap.md",
    "llm-wiki-architecture.png"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2"
  },
  "optionalDependencies": {
    "playwright": "^1.59.1",
    "tesseract.js": "^7.0.0"
  }
}
